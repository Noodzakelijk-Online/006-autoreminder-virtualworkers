DATABASE_URL=mysql://root:password@localhost:3306/va_dashboard
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
VITE_APP_ID=va-dashboard
OWNER_NAME=Your Name
OWNER_OPEN_ID=your_trello_user_id
VITE_APP_TITLE=VA Task Dashboard
VITE_APP_LOGO=/logo.png
BUILT_IN_FORGE_API_URL=https://forge.manus.ai
BUILT_IN_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key

# Optional integrations
PUBLIC_URL=http://localhost:3000
PORT=3000

# Redis — optional but recommended for production.
# When set, enables: distributed cache (L1), multi-instance WebSocket sync.
# Format: redis://[:password@]host[:port][/db]  or  rediss:// for TLS
# REDIS_URL=redis://localhost:6379

# Concurrency tuning (defaults shown)
# MAX_CONCURRENT_REQUESTS=100
# REQUEST_QUEUE_TIMEOUT_MS=30000

# Trello webhook callback URL — REQUIRED for webhook registration to work.
# Must be a publicly reachable HTTPS URL that Trello can POST to.
# In development, use a tunnel like ngrok: https://abc123.ngrok.io
# In production, set to your deployed domain: https://your-app.com
# This takes priority over APP_URL and PUBLIC_URL.
# WEBHOOK_BASE_URL=https://your-public-domain.com

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
NOTIFICATIONS_ENABLED=true
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_URL=http://localhost:11434
APP_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:3000
DEBUG=
