# ============================================================
# VA DASHBOARD — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit your real .env file to GitHub.
# Variables marked REQUIRED must be set for the app to start.
# Variables marked OPTIONAL can be left blank or commented out.
# ============================================================

# ── DATABASE (REQUIRED) ──────────────────────────────────────
# MySQL connection string.
# Quickest local option:
#   docker run --name va-mysql -e MYSQL_ROOT_PASSWORD=rootpass \
#     -e MYSQL_DATABASE=va_dashboard -p 3306:3306 -d mysql:8.0
DATABASE_URL=mysql://root:password@localhost:3306/va_dashboard

# ── TRELLO (REQUIRED) ────────────────────────────────────────
# Get your key and token at: https://trello.com/app-key
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here

# Your Trello member ID. Get it from:
# https://api.trello.com/1/members/me?key=YOUR_KEY&token=YOUR_TOKEN
OWNER_OPEN_ID=your_trello_user_id
OWNER_NAME=Your Name

# ── SESSION SECRET (REQUIRED) ────────────────────────────────
# Any random string, minimum 32 characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long

# ── AI / LLM (REQUIRED for AI features) ─────────────────────
# The app tries providers in this order: Groq → OpenAI → Together.ai → Forge
# At least one key is needed for APTLSS generation, ATIS analysis, and the chatbot.

# Option A: Groq — FREE, fast, no credit card needed
#   Sign up at: https://console.groq.com
#   Model used: llama-3.3-70b-versatile
GROQ_API_KEY=

# Option B: OpenAI — paid, higher quality
#   Sign up at: https://platform.openai.com
#   Model used: gpt-4o-mini
OPENAI_API_KEY=

# Option C: Together.ai — free tier available, access to DeepSeek V3
#   Sign up at: https://api.together.xyz
#   Model used: deepseek-ai/DeepSeek-V3
TOGETHER_API_KEY=

# Option D: OpenRouter — pay-per-use, access to many models
#   Sign up at: https://openrouter.ai
OPENROUTER_API_KEY=

# Option E: Ollama — fully local, no API key needed
#   Install from: https://ollama.ai
#   Run: ollama pull llama3.3
OLLAMA_URL=http://localhost:11434

# ── APP CONFIG (OPTIONAL) ────────────────────────────────────
PORT=3000
NODE_ENV=development
VITE_APP_TITLE=VA Task Dashboard
VITE_APP_LOGO=/logo.png
VITE_APP_ID=va-dashboard

# ── REDIS (OPTIONAL) ─────────────────────────────────────────
# Enables distributed caching and multi-instance WebSocket sync.
# Without Redis the app falls back to MySQL cache — fully functional.
# Start Redis: docker run --name va-redis -p 6379:6379 -d redis:7-alpine
# REDIS_URL=redis://localhost:6379

# ── TRELLO WEBHOOKS (OPTIONAL) ───────────────────────────────
# Required only for real-time Trello push updates (card changes trigger the app).
# Must be a publicly reachable HTTPS URL.
# For local development use ngrok:
#   ngrok http 3000
#   Then set: WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io
# Without this, manual sync still works — webhooks just won't auto-trigger.
# WEBHOOK_BASE_URL=https://your-public-domain.com

# ── EMAIL NOTIFICATIONS (OPTIONAL) ──────────────────────────
# Leave blank to disable email. In-app notifications still work without this.
# Get a free SendGrid account at: https://sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
NOTIFICATIONS_ENABLED=false

# ── CONCURRENCY TUNING (OPTIONAL) ────────────────────────────
MAX_CONCURRENT_REQUESTS=100
REQUEST_QUEUE_TIMEOUT_MS=30000

# ── LOGGING (OPTIONAL) ───────────────────────────────────────
# Levels: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ── APP URL (OPTIONAL) ───────────────────────────────────────
APP_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:3000

# ── NOT NEEDED FOR LOCAL DEV ─────────────────────────────────
# These were used by the original Manus-hosted environment.
# Local auth (username/password) works without them.
# Leave as-is or remove — they have no effect on local dev.
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Analytics (optional, dummy values to prevent Vite build/dev warnings)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

