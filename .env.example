# Runtime
DATABASE_URL=mysql://joyce:replace-with-local-password@127.0.0.1:3307/joyce_work_schedule

# APTLSS uses the configured OpenAI account as its only model provider.
# Compatible account-visible models are refreshed every 15 minutes.
APTLSS_MODEL_DISCOVERY_ENABLED=true
APTLSS_MODEL_CATALOG_TTL_MS=900000
APTLSS_MODEL_DISCOVERY_FAILURE_TTL_MS=60000
APTLSS_MODEL_DISCOVERY_TIMEOUT_MS=8000

# The account's available compatible OpenAI model families are discovered.
# Dated snapshots are deduplicated unless APTLSS_OPENAI_INCLUDE_SNAPSHOTS=true.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
APTLSS_OPENAI_MODEL_LADDER=
APTLSS_OPENAI_DISCOVERY_ENABLED=true
APTLSS_OPENAI_INCLUDE_SNAPSHOTS=false
APTLSS_OPENAI_MODEL_INCLUDE=
APTLSS_OPENAI_MODEL_EXCLUDE=
APTLSS_OPENAI_MAX_MODELS=0
APTLSS_OPENAI_TIMEOUT_MS=180000

# Review/repair controls. A higher stage reviews each accepted candidate.
APTLSS_LLM_REVIEW_ENABLED=true
APTLSS_LLM_MAX_CALLS_PER_RUN=32
APTLSS_LLM_MAX_RANK=

# Docker Compose database defaults
JOYCE_DB_PASSWORD=replace-with-db-password
MYSQL_ROOT_PASSWORD=replace-with-root-password
JOYCE_DB_PORT=3307
PORT=3000

# Trello API
TrelloAPIKey=replace-with-trello-api-key
TrelloAPIToken=replace-with-trello-api-token

# Trello Power-Up
TRELLO_POWERUP_API_KEY=replace-with-powerup-api-key
TRELLO_POWERUP_SECRET=replace-with-powerup-secret

# Optional production integrations
SCHEDULED_TASK_SECRET=replace-with-generated-scheduled-task-secret
TRELLO_WEBHOOK_CALLBACK_URL=
# Optional. If blank, TRELLO_POWERUP_SECRET is used for Trello webhook signature verification.
TRELLO_WEBHOOK_SECRET=

# Gmail read-only ingestion. These can instead be saved from Settings > Automation.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Optional for hosted deployments. Local mode derives http://<current-host>/api/integrations/gmail/callback.
GMAIL_OAUTH_REDIRECT_URI=
# Optional server-managed connection. The Settings OAuth flow stores an encrypted refresh token instead.
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_ACCOUNT_EMAIL=
# Required when OAuth credentials are saved through Settings. JWT_SECRET remains a legacy fallback.
GMAIL_CREDENTIALS_ENCRYPTION_KEY=
# Maximum accepted JSON/form request body. The dashboard does not require large uploads.
REQUEST_BODY_LIMIT=2mb
